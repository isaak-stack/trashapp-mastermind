rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Admin = phone number +15597744249
      return isSignedIn() && request.auth.token.phone_number == '+15597744249';
    }

    function isRep() {
      return isSignedIn();
    }

    function isOwner(repId) {
      return isSignedIn() && request.auth.uid == repId;
    }

    function isRecentDoc() {
      return request.resource.data.createdAt > request.time - duration.value(60, 's');
    }

    // ── PUBLIC READ ──────────────────────────────────────────
    // Job slots — customers need to see availability
    match /job_slots/{slotId} {
      allow read: if true;
      allow write: if isAdmin() || isRep();
    }

    // System config — needed by frontend for schedule, gas price
    match /system_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Zip intel — reps need to read their territory data
    match /zip_intel/{zipCode} {
      allow read: if isRep();
      allow write: if isAdmin();
    }

    // ── JOBS ────────────────────────────────────────────────
    // Customers can create jobs (from quote page, no auth required)
    // Reps and admin can read/update
    match /jobs/{jobId} {
      allow create: if true; // public — customers book without auth
      allow read: if isRep();
      allow update: if isRep();
      allow delete: if isAdmin();

      // Status history subcollection
      match /statusHistory/{entryId} {
        allow read: if isRep();
        allow create: if isRep();
      }

      // Messages subcollection (two-way SMS)
      match /messages/{messageId} {
        allow read: if isRep();
        allow create: if isRep();
      }
    }

    // ── REP DATA ─────────────────────────────────────────────
    match /rep_sessions/{sessionId} {
      allow read: if isAdmin() || isOwner(resource.data.repId);
      allow create: if isRep();
      allow update: if isAdmin() || isOwner(resource.data.repId);
      allow delete: if isAdmin();
    }

    match /live_reps/{repId} {
      allow read: if isRep();
      allow write: if isOwner(repId) || isAdmin();
    }

    match /crew_locations/{crewId} {
      allow read: if isRep();
      allow write: if isOwner(crewId) || isAdmin();
    }

    // ── TERRITORY ────────────────────────────────────────────
    match /territory_assignments/{weekId} {
      allow read: if isRep();
      allow write: if isAdmin();
    }

    // ── AI OS ─────────────────────────────────────────────────
    // Only admin can see agent data
    match /agent_reports/{reportId} {
      allow read, write: if isAdmin();
    }

    match /agent_messages/{messageId} {
      allow read, write: if isAdmin();
    }

    match /pending_approvals/{approvalId} {
      allow read, write: if isAdmin();
    }

    match /agent_state/{agentId} {
      allow read, write: if isAdmin();
    }

    match /agent_meetings/{weekId} {
      allow read, write: if isAdmin();
    }

    match /content_queue/{postId} {
      allow read, write: if isAdmin();
    }

    // ── PRICING + INTEL ──────────────────────────────────────
    match /pricing_intel/{docId} {
      allow read: if isRep();
      allow write: if isAdmin();
    }

    match /job_applications/{appId} {
      allow create: if true; // public — job seekers apply without auth
      allow read, update, delete: if isAdmin();
    }

    match /customer_follow_ups/{followUpId} {
      allow read, write: if isRep();
    }

    match /schedule_changes/{changeId} {
      allow read, write: if isAdmin();
    }
match /doors/{doorId} {
      allow read: if isAdmin() || isRep();
      allow create: if isRep();
      allow update: if isAdmin() || isRep();
      allow delete: if isAdmin();
    }

    match /reps/{repId} {
      allow read: if isRep();
      allow write: if isAdmin() || isOwner(repId);
    }

    match /broadcasts/{broadcastId} {
      allow read: if isRep();
      allow write: if isAdmin();
    }

    match /scripts/{scriptId} {
      allow read: if isRep();
      allow write: if isAdmin();
    }

    match /commission_log/{entryId} {
      allow read, write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isRep();
      allow write: if isAdmin();
    }

    match /health_log/{entryId} {
      allow read, write: if isAdmin();
    }
match /crews/{crewId} {
      allow read: if isRep();
      allow write: if isAdmin();
    }

    match /financials/{docId} {
      allow read, write: if isAdmin();
    }

match /payouts/{payoutId} {
      allow read: if isAdmin() || isRep();
      allow write: if isAdmin();
    }
    match /review_queue/{itemId} {
      allow read, write: if isAdmin();
    }

    match /territories/{territoryId} {
      allow read: if isRep();
      allow write: if isAdmin();
    }

    match /fulfillment/{jobId} {
      allow read: if isRep();
      allow write: if isAdmin() || isRep();
    }

    match /social_posts/{postId} {
      allow read, write: if isAdmin();
    }

    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    match /intel/{docId} {
      allow read: if isRep();
      allow write: if isAdmin();
    }
match /commissions/{commissionId} {
      allow read: if isAdmin() || isRep();
      allow write: if isAdmin();
    }

    match /daily_financials/{docId} {
      allow read, write: if isAdmin();
    }

    // ── CREW MEMBERS ─────────────────────────────────────────
    // Crew dashboard authorization check — any signed-in user can
    // read (to check their own membership); only admin writes.
    match /crew_members/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.phone_number in ['+15597744249', '+19096729370'];
    }

    // ── SANDBOX COLLECTIONS ──────────────────────────────────
    // Admin sandbox/demo mode — writes go here instead of real
    // collections. Any signed-in user can read/write; data is
    // wiped automatically by the client on sign out.
    // NOTE: Firestore rules don't support wildcards on collection
    // names, so each sandbox_* collection needs an explicit rule.
    match /sandbox_jobs/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_doors/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_rep_sessions/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_crew_sessions/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_leads/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_commissions/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_pending_notifications/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_reps/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_sessions/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_live_reps/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_crew_locations/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_scripts/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_customers/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_admin_notifications/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_daily_summary/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_client_errors/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_job_slots/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_broadcasts/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_crews/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_social_posts/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_system_logs/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_agent_messages/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_crew_members/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_system_config/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_territory_assignments/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_pending_approvals/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_content_queue/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_review_queue/{docId} { allow read, write: if request.auth != null; }
    match /sandbox_daily_financials/{docId} { allow read, write: if request.auth != null; }

    // ── DENY ALL ELSE ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
