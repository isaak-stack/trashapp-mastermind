# ===========================================
# TrashApp Mastermind — Environment Variables
# ===========================================
# Copy this file to .env and fill in your credentials.
# The mastermind will start even with blank values —
# each service activates when its variables are filled in.

# Firebase Admin SDK
# Get these from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=trashapp-reps
FIREBASE_CLIENT_EMAIL=           # From Firebase service account JSON  e.g. firebase-adminsdk-xxxxx@trashapp-reps.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=            # From Firebase service account JSON (wrap in double quotes, keep \n line breaks)

# Twilio — https://www.twilio.com/console
TWILIO_ACCOUNT_SID=              # Starts with AC...
TWILIO_AUTH_TOKEN=               # 32-character hex string
TWILIO_PHONE_NUMBER=             # Your purchased Twilio number  e.g. +15591234567

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=               # Starts with sk_live_ or sk_test_
STRIPE_WEBHOOK_SECRET=           # Starts with whsec_  (from dashboard.stripe.com/webhooks after adding endpoint)

# Anthropic Claude API — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=               # Starts with sk-ant-  (REQUIRED for AI OS agents, SMS responses, intel analysis, territory optimization)

# Calendly — DEPRECATED
# CALENDLY_WEBHOOK_SECRET=         # DEPRECATED — native slot booking replaced Calendly

# Dashboard
DASHBOARD_PORT=3000              # Port for the dispatch dashboard
DASHBOARD_PASSWORD=              # Leave blank for no password (dev mode)

# Admin
ADMIN_PHONE=+15597744249         # Receives alerts and daily summaries

# Railway Quote API
RAILWAY_QUOTE_API=https://junk-quote-api-production.up.railway.app/api/quote

# Google Maps (used by admin console and quote page)
GOOGLE_MAPS_API_KEY=AIzaSyDtkh_G25Kr6YaAeNJOd9D9YJuyZnKvu08

# Calendly (rep platform uses widget with customer prefill)
CALENDLY_URL=https://calendly.com/trashappjunkremoval

# HubSpot (contact sync on quote page and rep same-day close)
HUBSPOT_PORTAL_ID=245673285
HUBSPOT_FORM_ID=b243f733-e7e7-4418-8d99-e5a067d889e6

# EIA Gas Price API — free key at https://www.eia.gov/opendata/register.php
# Optional — without it uses DEMO key which may be rate limited
EIA_API_KEY=
